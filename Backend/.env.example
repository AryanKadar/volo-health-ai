# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_BASE=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-02-01

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173

# ── Token & Model Configuration ───────────────────────────────────────────────
# Max tokens GPT can return in a MAIN CHAT response
AZURE_OPENAI_MAX_COMPLETION_TOKENS=512

# Max tokens for Topic Guard classifier (very short – YES/NO only)
AZURE_OPENAI_TOPIC_GUARD_MAX_TOKENS=5

# Max tokens for Summary Update call (short, ~100 words output)
AZURE_OPENAI_SUMMARY_MAX_TOKENS=150

# Temperature – 0.7 is balanced (0 = deterministic, 1 = creative)
AZURE_OPENAI_TEMPERATURE=0.7

# Topic Guard temperature – 0 for consistent YES/NO classification
AZURE_OPENAI_TOPIC_GUARD_TEMPERATURE=0.0
